# Polling and alert behavior
ProductName=Arcane EDR
ServiceName=ArcaneEDR
ServiceDisplayName=Arcane EDR
ServiceDescription=Monitors host, process, persistence, PowerShell, Sysmon, and network activity for suspicious behavior on unattended agent workstations.
PollIntervalSeconds=10
AlertCooldownSeconds=300
MinimumEmailScore=60
# Optional v0.3 rule policy tuning. Disabled rules/categories are skipped before
# local alert logging, incident grouping, response, and external delivery.
# Minimum score maps affect external delivery only.
DisabledRuleIds=
DisabledRuleCategories=
RuleMinimumEmailScores=NET-DIRECT-IP-WEB-EGRESS=90,NET-EGRESS-UNUSUAL-PORT=90,NET-EGRESS-NEW-UNTRUSTED=80,NET-BEACON-TIMING-LOW-RISK=90,PS-SUSPICIOUS-COMMAND=90,BASELINE-NEW-PROCESS-DOMAIN=95,BASELINE-NEW-PROCESS-DESTINATION=95
CategoryMinimumEmailScores=
ExternalAlertProviderMinimumScores=
ExternalAlertProviderMaxPerHour=
ExternalAlertMaxPerDispatch=3
ExternalAlertMaxPerHour=12
# External-only dampening for repeated low-value patterns. This keeps local
# alert logging and incident grouping intact, but avoids repeated email/API
# notifications for the same stable low-score behavior.
EnableLowValueRepeatDampening=true
LowValueRepeatDampeningMaximumScore=60
LowValueRepeatDampeningWindowMinutes=60
LowValueRepeatDampeningMaxExternalAlertsPerWindow=2
LowValueRepeatDampeningCategories=Network,DNS,Baseline,Reputation,Process
ExternalAlertRetryEnabled=true
ExternalAlertRetryIntervalSeconds=300
ExternalAlertRetryMaxIntervalSeconds=3600
ExternalAlertRetryMaxAttempts=12
ExternalAlertRetryMaxQueued=50
ExternalAlertRetryMaxPerPoll=3
ExternalAlertRetryQueueFile=ArcaneExternalAlertRetry.queue
# Maintenance context labels expected admin/build/publish activity and raises
# the external-alert threshold for matching alerts. Matching alerts are still
# logged locally and grouped into incidents.
EnableMaintenanceContext=true
MaintenanceContextExternalAlertMinimumScore=95
MaintenanceContextTermGroups=icacls|/inheritance:r,icacls|/grant:r,powershell|-executionpolicy bypass|build.ps1,powershell|-executionpolicy bypass|publish.ps1,powershell|-executionpolicy bypass|install-service.ps1,ArcaneEDR.exe|--validate-config,Stop-Service|ArcaneEDR,Start-Service|ArcaneEDR,sc.exe|ArcaneEDR|failure,sc.exe|ArcaneEDR|delete,admin-task-runner.ps1|ArcaneEDR
# Stronger external-only suppression escape hatch. Terms inside a group are
# separated by | and must all appear in the alert text. The alert is still
# logged locally, but no external notification is sent.
ExternalAlertSuppressionTermGroups=
RequireExternalAlerting=false
LogDirectory=logs
MaxLogFileBytes=10485760
EnableIncidentGrouping=true
IncidentStoreFile=ArcaneIncidents.jsonl
IncidentWindowMinutes=30
IncidentMinimumScore=60

# Service health notifications and self-healing state.
NotifyOnServiceStart=true
NotifyOnServiceStop=false
NotifyOnCrashRecovery=true
EnableDailySummary=true
DailySummaryIntervalHours=24
DailySummaryLocalTime=08:00
DailySummaryTimeZoneId=Pacific Standard Time
DailySummaryScore=60
EnableDailySummaryOpenAiAnalysis=true
DailyReportDestinations=ExternalAlertSinks,LocalArchive
DailyReportSections=QuickVerdict,CriticalCallouts,AtAGlance,SignalSummary,FalsePositiveContext,HighSignalDetails,AutomationActivity,OpenAIReview,TuningNotes
DailyReportCriticalCalloutRows=5
DailyReportHighSignalRows=7
DailyReportBucketRows=6
DailyReportAgentBucketRows=3
EnableDailyReportArchive=true
DailyReportArchiveDirectory=reports
DailyReportArchiveFormats=Markdown,Json
# Optional report-specific webhook destination. Add Webhook to
# DailyReportDestinations to post the redacted JSON report payload here.
DailyReportWebhookUrl=
DailyReportWebhookSecretEnvironmentVariable=
DailyReportWebhookSecretHeaderName=Authorization
DailyReportWebhookSecretPrefix=Bearer
DailyReportWebhookTimeoutSeconds=15
HealthHeartbeatSeconds=60

# Compact hourly AI log analysis. Payloads are capped to avoid unnecessary
# token usage. The service sends redacted summaries only: counters, alert
# metadata, and sanitized aggregate rule/category/score/reason context, not raw
# command lines, alert bodies, entities, paths, IPs, URLs, emails, or secrets.
EnableOpenAiLogAnalysis=false
OpenAIAnalysisIntervalMinutes=60
OpenAIAnalysisScoreThreshold=95
OpenAIAnalysisBaselineEmailMinimumScore=95
OpenAIAnalysisMinimumIncludedAlertScore=60
OpenAIAnalysisBaselineMinimumIncludedAlertScore=95
OpenAIAnalysisExcludedRuleIds=OPENAI-LOG-ANALYSIS-ALERT,OPENAI-LOG-ANALYSIS-TEST,SERVICE-STARTED,SERVICE-STOPPED,SERVICE-DAILY-SUMMARY,SERVICE-HEALTH-TEST,TEST-ALERT-DELIVERY
AIAnalysisProvider=OpenAI
# Optional generic aliases for OpenAI-compatible APIs. Empty values fall back to
# the OpenAIAnalysis* settings below. Set AIAnalysisAuthHeaderName empty only for
# trusted no-auth local endpoints.
AIAnalysisModel=
AIAnalysisApiKeyEnvironmentVariable=
AIAnalysisApiUrl=
AIAnalysisAuthHeaderName=Authorization
AIAnalysisAuthHeaderPrefix=Bearer
OpenAIAnalysisModel=gpt-5.5
OpenAIApiKeyEnvironmentVariable=OPENAI_API_KEY
OpenAIAnalysisApiUrl=https://api.openai.com/v1/responses
OpenAIAnalysisMaxLogLines=80
OpenAIAnalysisMaxAlertLines=80
OpenAIAnalysisMaxChars=12000

# Encoded command-line detection catches PowerShell -EncodedCommand and long
# base64-like CLI arguments, then decodes UTF-16LE/UTF-8 where possible.
DetectEncodedCommandLines=true
EncodedCommandMinimumLength=80

# External alert delivery provider. Use one provider or a comma-separated list.
# Supported values: Disabled, Brevo, Smtp, Webhook, GenericHttpApi, LocalJsonl,
# WindowsEventLog.
ExternalAlertProvider=Disabled

# Brevo transactional email API settings.
# BREVO_API_KEY is read from Process, User, then Machine environment scope.
# Sender must be a registered/verified Brevo sender.
BrevoApiUrl=https://api.brevo.com/v3/smtp/email
BrevoApiKeyEnvironmentVariable=BREVO_API_KEY
BrevoSenderEmail=alerts@example.com
BrevoSenderName=Arcane EDR
BrevoRecipientEmail=security@example.com
BrevoRecipientName=Security Team

# SMTP email settings. Password is optional for anonymous relays; otherwise put
# it in the configured environment variable.
SmtpHost=smtp.example.com
SmtpPort=587
SmtpEnableSsl=true
SmtpTimeoutSeconds=15
SmtpUsername=alerts@example.com
SmtpPasswordEnvironmentVariable=SMTP_PASSWORD
SmtpSenderEmail=alerts@example.com
SmtpSenderName=Arcane EDR
SmtpRecipientEmail=security@example.com
SmtpRecipientName=Security Team

# Webhook settings. WebhookAlertUrl is required only when the Webhook provider
# is enabled. Secret settings are optional.
WebhookAlertUrl=
WebhookSecretEnvironmentVariable=
WebhookSecretHeaderName=Authorization
WebhookSecretPrefix=Bearer
WebhookTimeoutSeconds=15

# Generic HTTP/API alert settings. GenericHttpApiAlertUrl is required only when
# the GenericHttpApi provider is enabled. Secret settings are optional.
GenericHttpApiAlertUrl=
GenericHttpApiSecretEnvironmentVariable=
GenericHttpApiSecretHeaderName=Authorization
GenericHttpApiSecretPrefix=Bearer
GenericHttpApiTimeoutSeconds=15

# Local JSONL alert sink. This writes alerts that pass external-alert thresholds
# to a separate local JSONL file. It is useful for forwarding or later import.
LocalJsonlAlertSinkFile=ArcaneExternalAlerts.jsonl

# Windows Event Log alert sink.
WindowsEventLogAlertSource=ArcaneEDR
WindowsEventLogAlertLogName=Application
WindowsEventLogAlertEventId=9100

# Optional Sysmon ingestion. If Sysmon is not installed, the monitor falls back
# to netstat-based telemetry and logs a warning.
EnableSysmonIngestion=true
SysmonServiceName=Sysmon64
SysmonEventLogName=Microsoft-Windows-Sysmon/Operational
SysmonLookbackMinutes=10
SysmonMaxEventsPerPoll=200
PersistEventLogWatermarks=true
EventLogWatermarkFile=ArcaneEventLogWatermarks.tsv

# Host telemetry ingestion. These add script, auth, service/task, and
# persistence visibility used for RAT-oriented detection.
EnablePowerShellLogIngestion=true
PowerShellEventLogName=Microsoft-Windows-PowerShell/Operational
PowerShellLookbackMinutes=10
PowerShellMaxEventsPerPoll=200
EnableWindowsEventIngestion=true
WindowsSecurityEventLogName=Security
WindowsSystemEventLogName=System
WindowsEventLookbackMinutes=10
WindowsEventMaxEventsPerPoll=200
AuthSpecialPrivilegeRepeatDampeningMinutes=60
AuthSpecialPrivilegeRemoteCorrelationMinutes=15
EnablePersistenceInventory=true
PersistenceInventoryIntervalMinutes=60

# Narrow Sysmon-backed file-create detection. This is not broad file auditing:
# the bundled Sysmon config requests a small set of high-risk target filenames,
# and Arcane only alerts when executable/script drops, sensitive-looking files,
# suspicious writers, or agent-root boundary violations are present.
EnableHighSignalFileDetection=true
HighRiskFilePathIndicators=\appdata\roaming\microsoft\windows\start menu\programs\startup\,\programdata\microsoft\windows\start menu\programs\startup\,\windows\system32\tasks\,\appdata\local\google\chrome\user data\default\extensions\,\appdata\local\microsoft\edge\user data\default\extensions\
HighRiskFileExtensions=.exe,.dll,.scr,.com,.msi,.msp,.ps1,.psm1,.vbs,.vbe,.js,.jse,.hta,.bat,.cmd,.lnk,.url,.jar
SensitiveFileNameIndicators=apikey,api_key,access_token,refresh_token,client_secret,private_key,id_rsa,id_ed25519,.pem,.pfx,.env,credentials,token.json

# First-seen artifact memory and local JSON rules.
EnableReputationCache=true
ReputationCacheFile=ArcaneReputation.tsv
EnableCustomRules=true
CustomRulesFile=custom-rules.json

# Baseline learning stores process/destination and process/domain pairs.
# Leave learning mode enabled for initial deployment to reduce first-run noise.
BaselineEnabled=true
BaselineLearningMode=true
BaselineLearningEmailMinimumScore=90
BaselineWarmupHours=24
BaselineFile=ArcaneBaseline.tsv

# Agentic AI workstation profile. These settings label and correlate existing
# alerts that involve known unattended agent processes. They do not increase
# score, trigger response, or send alerts by themselves.
EnableAgentProfile=true
AgentProcessNames=Codex.exe,codex.exe
AgentChildProcessNames=powershell.exe,pwsh.exe,cmd.exe,git.exe,git-remote-https.exe,node.exe,npm.exe,npm.cmd,python.exe,python3.exe,pip.exe,pip3.exe,curl.exe
AgentWorkspaceRoots=
AgentPublishRoots=
AgentPackageManagerProcesses=git.exe,git-remote-https.exe,node.exe,npm.exe,npm.cmd,python.exe,python3.exe,pip.exe,pip3.exe,curl.exe
AgentApprovedAdminTaskNames=\ArcaneEDR\PublishRestart,\ArcaneEDR\InstallService,\ArcaneEDR\UninstallService,\ArcaneEDR\InstallSysmon,\ArcaneEDR\ValidateAdmin
AgentSecretIndicatorTerms=apikey,api_key,access_token,refresh_token,client_secret,private_key,id_rsa,.pem,.pfx,.env
EnableAgentActivityLedger=true
AgentActivityLedgerFile=ArcaneAgentActivity.jsonl
AgentActivityLedgerMinimumScore=60

# Optional response. Keep AlertOnly unless you intentionally want the service to
# add firewall blocks or terminate processes on high-confidence alerts.
ResponseMode=AlertOnly
ResponseMinimumScore=95

# Local listening ports expected on this machine. Unexpected loopback-only
# listeners are classified separately at lower severity than reachable listeners.
# Comma-separated integers. Example: 22,80,443,3000,5000
AllowedListeningPorts=68,135,137,138,139,445,546,1900,5040,5050,5353,5355,7680,49664-49680

# Remote ports that are normal for outbound traffic.
AllowedOutboundPorts=53,80,123,443,587,993,995

# Remote ports that are normal only for specific processes. Use semicolons
# between process entries and commas or ranges for ports.
# Example: ProcessAllowedOutboundPorts=browser.exe=5228-5230;sync.exe=8081
ProcessAllowedOutboundPorts=Codex.exe=5228

# External networks that should not alert. CIDR notation or exact IPs.
# Example: 203.0.113.10,198.51.100.0/24
AllowedRemoteCidrs=

# External networks that should always alert. CIDR notation or exact IPs.
# Use this for known-bad indicators from your own threat intelligence.
BlockedRemoteCidrs=
BlockedDomains=
BlockedHashes=

# Dynamic DNS suffixes often used for disposable access. Tune as needed.
DynamicDnsSuffixes=duckdns.org,no-ip.org,no-ip.com,hopto.org,ddns.net,ddns.info,dynv6.net,serveo.net,ngrok-free.app,trycloudflare.com,localtunnel.me

# Known DNS-over-HTTPS resolver IPs. Keep this list small and explicit.
DohProviderCidrs=1.1.1.1,1.0.0.1,8.8.8.8,8.8.4.4,9.9.9.9,149.112.112.112

# DNS egress control. Enterprise guidance recommends routing DNS only through
# authorized resolvers. Set EnforceAuthorizedDnsResolvers=true after filling
# AllowedDnsResolvers.
EnforceAuthorizedDnsResolvers=false
AllowedDnsResolvers=

# Process names allowed to create external outbound connections.
# Keep this narrow for an agent sandbox. Case-insensitive.
TrustedProcesses=svchost.exe,System,System.exe,lsass.exe,services.exe,spoolsv.exe,wininit.exe,OneDrive.exe,Code.exe,Codex.exe,codex.exe,chrome.exe,msedge.exe,explorer.exe,MsMpEng.exe,MpDefenderCoreService.exe,msedgewebview2.exe,ArcaneEDR.exe,StartMenuExperienceHost.exe

# Living-off-the-land binaries and script runtimes that should rarely initiate
# direct external connections in this sandbox.
LolbinProcesses=powershell.exe,pwsh.exe,cmd.exe,wscript.exe,cscript.exe,mshta.exe,rundll32.exe,regsvr32.exe,certutil.exe,bitsadmin.exe,installutil.exe,wmic.exe,msiexec.exe,reg.exe,schtasks.exe,forfiles.exe,ftp.exe,tftp.exe,python.exe,pythonw.exe,node.exe,java.exe,javaw.exe,perl.exe,ruby.exe

# Remote management tools frequently abused for RAT-like access. Tune for tools
# you intentionally use.
KnownRmmProcesses=anydesk.exe,teamviewer.exe,teamviewer_service.exe,rustdesk.exe,screenconnect.clientservice.exe,screenconnect.windowsclient.exe,splashtopstreamer.exe,srservice.exe,ateraagent.exe,ngrok.exe,cloudflared.exe,remcos.exe,njrat.exe,quasar.exe,asyncclient.exe,meshagent.exe

# Parents commonly seen in initial access or script-staging chains.
SuspiciousParentProcesses=winword.exe,excel.exe,powerpnt.exe,outlook.exe,acrord32.exe,chrome.exe,msedge.exe,firefox.exe,iexplore.exe,7zfm.exe,winrar.exe,explorer.exe

# Command-line fragments often associated with download, encoded execution,
# proxying, or stealthy script launch.
SuspiciousCommandLineTerms=-enc,-encodedcommand,frombase64string,downloadstring,downloadfile,invoke-webrequest,iwr ,curl ,wget ,bitsadmin,certutil,regsvr32,mshta,http://,https://, -nop, -w hidden, -windowstyle hidden, -executionpolicy bypass, -ep bypass, rundll32,javascript:,vbscript:,/transfer,/create

# User-writable paths are high-risk launch locations for unsigned networked code.
UserWritablePathIndicators=\users\,\appdata\,\temp\,\downloads\,\desktop\,\documents\,\programdata\

# Persistence entries under these known Windows/vendor locations are still
# inventoried, but they are not treated as suspicious merely because they use a
# Windows LOLBin or ProgramData path. Names alone are not trusted; trusted
# persistence also needs a trusted path or trusted signer, and no suspicious
# command, untrusted user-writable path, or RMM traits.
TrustedPersistenceNamePrefixes=\Microsoft\Windows\,MDCoreSvc,WinDefend
TrustedPersistencePathIndicators=\windows\system32\,\windows\syswow64\,%windir%\system32\,%windir%\syswow64\,%systemroot%\system32\,%systemroot%\syswow64\,\program files\,\program files (x86)\,\programdata\microsoft\windows defender\
TrustedPersistenceSignerSubjects=Microsoft Windows,Microsoft Corporation,Microsoft Windows Publisher

# Ports frequently associated with reverse shells, proxies, IRC C2, or tunnels.
HighRiskRemotePorts=4444,1337,31337,6667,6668,6669,6697,9001,9050,9051,1080,8080,8443

# Internal ports commonly abused for lateral movement.
LateralMovementPorts=22,135,139,445,3389,5985,5986

# Alert when a process opens this many distinct external TCP connections in one poll.
ConnectionBurstThreshold=25

# Beaconing detection: repeated new connections to the same remote endpoint with
# low interval variation.
BeaconMinimumSamples=5
BeaconMaxAverageIntervalSeconds=600
BeaconMaxJitterRatio=0.25

<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ArcaneEDR_Gui.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ArcaneEDR_Gui.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource PagePadding}" Spacing="16">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="About" />
            <Grid ColumnSpacing="12" RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Arcane EDR" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Local safety layer for unattended agent workstations" TextWrapping="WrapWholeWords" />
                        <Button Click="Version_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="16" Glyph="&#xE946;" />
                                <TextBlock Text="Version" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Installed Context" />
                        <TextBlock x:Name="ContextText" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </Grid>
            <StackPanel Spacing="8">
                <TextBlock FontWeight="SemiBold" Text="Version output" />
                <Border MinHeight="260" Style="{StaticResource ConsolePanelStyle}">
                    <TextBlock x:Name="AboutOutputText" Style="{StaticResource ConsoleTextStyle}" />
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>

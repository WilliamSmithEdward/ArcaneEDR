<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ArcaneEDR_Gui.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ArcaneEDR_Gui.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="28,18,28,28" Spacing="16">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="About" />
            <Grid ColumnSpacing="12" RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Arcane EDR" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Local safety layer for unattended agent workstations" TextWrapping="WrapWholeWords" />
                        <Button Click="Version_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="16" Glyph="&#xE946;" />
                                <TextBlock Text="Version" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Installed Context" />
                        <TextBlock x:Name="ContextText" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </Grid>
            <TextBox
                x:Name="AboutOutputText"
                AcceptsReturn="True"
                FontFamily="Consolas"
                Header="Version output"
                IsReadOnly="True"
                MinHeight="260"
                TextWrapping="NoWrap" />
        </StackPanel>
    </ScrollViewer>
</Page>

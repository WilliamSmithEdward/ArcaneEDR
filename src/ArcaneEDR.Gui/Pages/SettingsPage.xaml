<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ArcaneEDR_Gui.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:ArcaneEDR_Gui.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ArcaneEDR_Gui.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer
        controls:PageScrollBehavior.UseReliableWheel="True"
        Style="{StaticResource PageScrollViewerStyle}">
        <StackPanel Padding="{StaticResource PagePadding}" Spacing="16">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Settings" />
            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock FontWeight="SemiBold" Text="Windows startup" />
                    <ToggleSwitch
                        x:Name="StartOnLoginSwitch"
                        Header="Start on Windows login"
                        OffContent="Off"
                        OnContent="On"
                        Toggled="StartupSwitch_Toggled" />
                    <ToggleSwitch
                        x:Name="StartMinimizedSwitch"
                        Header="Start minimized to tray on Windows login"
                        OffContent="Off"
                        OnContent="On"
                        Toggled="StartupSwitch_Toggled" />
                    <TextBlock
                        x:Name="StartupStatusText"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock FontWeight="SemiBold" Text="Theme" />
                    <ComboBox x:Name="ThemeBox" SelectionChanged="ThemeBox_SelectionChanged" SelectedIndex="0">
                        <ComboBoxItem Content="Default" />
                        <ComboBoxItem Content="Light" />
                        <ComboBoxItem Content="Dark" />
                    </ComboBox>
                </StackPanel>
            </Border>
            <StackPanel Spacing="8">
                <TextBlock FontWeight="SemiBold" Text="Current Arcane paths" />
                <Border MinHeight="220" Style="{StaticResource ConsolePanelStyle}">
                    <TextBlock x:Name="SettingsPathText" Style="{StaticResource ConsoleTextStyle}" />
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>

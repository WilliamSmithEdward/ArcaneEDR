<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ArcaneEDR_Gui.Pages.ConfigurationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:ArcaneEDR_Gui.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="{StaticResource PagePadding}" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Configuration" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Edit runtime, deployment, and policy settings with validation" />
            </StackPanel>
            <Button
                Grid.Column="1"
                AutomationProperties.Name="Validate configuration"
                Click="Validate_Click"
                ToolTipService.ToolTip="Validate configuration">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="16" Glyph="&#xE73E;" />
                    <TextBlock Text="Validate" />
                </StackPanel>
            </Button>
            <Button
                Grid.Column="2"
                AutomationProperties.Name="Open runtime config"
                Click="OpenConfig_Click"
                ToolTipService.ToolTip="Open runtime config">
                <FontIcon FontSize="16" Glyph="&#xE8A5;" />
            </Button>
            <Button
                Grid.Column="3"
                AutomationProperties.Name="Open config folder"
                Click="OpenFolder_Click"
                ToolTipService.ToolTip="Open config folder">
                <FontIcon FontSize="16" Glyph="&#xE838;" />
            </Button>
            <Button
                Grid.Column="4"
                AutomationProperties.Name="Configuration help"
                Click="Help_Click"
                ToolTipService.ToolTip="Explain configuration guardrails">
                <FontIcon FontSize="16" Glyph="&#xE897;" />
            </Button>
        </Grid>

        <TabView Grid.Row="1">
            <TabViewItem Header="Guided" IsClosable="False">
                <ScrollViewer
                    controls:PageScrollBehavior.UseReliableWheel="True"
                    Style="{StaticResource PageScrollViewerStyle}">
                    <StackPanel Spacing="14">
                        <InfoBar
                            IsOpen="True"
                            Severity="Informational"
                            Title="Validation is the source of truth"
                            Message="Saves update the real Arcane config files, create timestamped backups, then run the service validator." />

                        <Grid ColumnSpacing="12" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel Spacing="10">
                                    <TextBlock FontWeight="SemiBold" Text="Operating mode" />
                                    <InfoBar
                                        IsOpen="True"
                                        Severity="Warning"
                                        Title="Active response can disrupt the workstation"
                                        Message="Keep AlertOnly unless you intentionally want Arcane to block remote IPs or terminate processes. Saves that enable response require confirmation." />
                                    <ComboBox
                                        x:Name="ResponseModeBox"
                                        Header="Response mode"
                                        ToolTipService.ToolTip="AlertOnly is the safe default. Active modes can block network traffic or terminate processes only when response gates also allow it.">
                                        <ComboBoxItem Content="AlertOnly" />
                                        <ComboBoxItem Content="DryRunBlockRemoteIp" />
                                        <ComboBoxItem Content="DryRunTerminateProcess" />
                                        <ComboBoxItem Content="DryRunBlockAndTerminate" />
                                        <ComboBoxItem Content="BlockRemoteIp" />
                                        <ComboBoxItem Content="TerminateProcess" />
                                        <ComboBoxItem Content="BlockAndTerminate" />
                                    </ComboBox>
                                    <TextBox x:Name="ResponseMinimumScoreBox" Header="Response minimum score" ToolTipService.ToolTip="Minimum score before response evaluation. Higher is safer." />
                                    <ToggleSwitch x:Name="FirewallResponseSwitch" Header="Enable firewall block response" ToolTipService.ToolTip="Allows Arcane-managed firewall blocks only when response mode and policy also allow them." />
                                    <ToggleSwitch x:Name="ProcessTerminationSwitch" Header="Enable process termination response" ToolTipService.ToolTip="Allows process termination only when response mode and policy also allow it. Keep off unless testing rollback." />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}">
                                <StackPanel Spacing="10">
                                    <TextBlock FontWeight="SemiBold" Text="External alerting" />
                                    <ComboBox x:Name="ExternalAlertProviderBox" Header="Provider" ToolTipService.ToolTip="External alert sink. Local JSONL evidence is preserved regardless of provider choice.">
                                        <ComboBoxItem Content="Disabled" />
                                        <ComboBoxItem Content="Brevo" />
                                        <ComboBoxItem Content="Smtp" />
                                        <ComboBoxItem Content="Webhook" />
                                        <ComboBoxItem Content="GenericHttpApi" />
                                        <ComboBoxItem Content="LocalJsonl" />
                                        <ComboBoxItem Content="WindowsEventLog" />
                                    </ComboBox>
                                    <TextBox x:Name="MinimumEmailScoreBox" Header="Minimum external alert score" ToolTipService.ToolTip="Minimum score for ordinary external alert delivery before per-rule and provider limits." />
                                    <ToggleSwitch x:Name="DailySummarySwitch" Header="Enable daily summary" ToolTipService.ToolTip="Sends or archives the daily operator report at the configured local time." />
                                    <ToggleSwitch x:Name="ServiceStartSwitch" Header="Notify on service start" ToolTipService.ToolTip="Service lifecycle notifications bypass ordinary alert rate limits." />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Style="{StaticResource SectionCardStyle}">
                                <StackPanel Spacing="10">
                                    <TextBlock FontWeight="SemiBold" Text="AI review" />
                                    <ToggleSwitch x:Name="AIAnalysisSwitch" Header="Enable AI analysis" ToolTipService.ToolTip="Optional compact AI review of redacted summaries. Disabled in repo defaults." />
                                    <TextBox x:Name="AIProviderBox" Header="Providers" ToolTipService.ToolTip="Comma-separated AI providers configured in Arcane. Provider adapters must be complete before being marked supported." />
                                    <TextBox x:Name="AIModelBox" Header="Model" ToolTipService.ToolTip="Provider model name. Keep payload caps and redaction enabled." />
                                    <TextBox x:Name="AIEnvVarBox" Header="API key environment variable" ToolTipService.ToolTip="Environment variable name only. Do not paste API keys into config." />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource SectionCardStyle}">
                                <StackPanel Spacing="10">
                                    <TextBlock FontWeight="SemiBold" Text="Remote enrichment" />
                                    <ToggleSwitch x:Name="CountryBlocksSwitch" Header="Country blocks" ToolTipService.ToolTip="Use local country block data before optional external lookups." />
                                    <ToggleSwitch x:Name="RdapSwitch" Header="RDAP owner / ASN" ToolTipService.ToolTip="Uses RDAP to resolve owner, ASN, and country context when available." />
                                    <ToggleSwitch x:Name="IpApiSwitch" Header="ip-api.com hook" ToolTipService.ToolTip="Optional fallback. Free use is non-commercial only; commercial use requires a subscription." />
                                    <ToggleSwitch x:Name="IpWhoisSwitch" Header="ipwhois.io / ipwho.is hook" ToolTipService.ToolTip="Optional fallback. Free use is non-commercial only; commercial use requires a subscription." />
                                    <TextBox x:Name="GeoMaxLookupsBox" Header="External geo lookups per poll" ToolTipService.ToolTip="Bounds external enrichment calls per poll so one provider cannot stall monitoring." />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Style="{StaticResource SectionCardStyle}">
                                <StackPanel Spacing="10">
                                    <TextBlock FontWeight="SemiBold" Text="Baseline and agent context" />
                                    <ToggleSwitch x:Name="BaselineLearningSwitch" Header="Baseline learning mode" ToolTipService.ToolTip="Keeps first-seen baseline activity quieter externally while preserving local evidence." />
                                    <TextBox x:Name="AgentProcessNamesBox" Header="Agent process names" ToolTipService.ToolTip="Known local agent processes used for labeling and guardrail context." />
                                    <TextBox x:Name="AgentWorkspaceRootsBox" Header="Agent workspace roots" ToolTipService.ToolTip="Expected agent workspace roots. Use narrow durable paths." />
                                    <TextBox x:Name="AgentPublishRootsBox" Header="Agent publish roots" ToolTipService.ToolTip="Expected publish/install roots used to identify maintenance context." />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource SectionCardStyle}">
                                <StackPanel Spacing="10">
                                    <TextBlock FontWeight="SemiBold" Text="Paths" />
                                    <TextBox x:Name="LogDirectoryBox" Header="Log directory" ToolTipService.ToolTip="Mutable local evidence directory. MSI defaults to ProgramData." />
                                    <TextBox x:Name="PolicyFileBox" Header="Policy file" ToolTipService.ToolTip="Unified policy JSON for allow, block, response, remote endpoint, and detection tuning." />
                                    <TextBox x:Name="DestinationRootBox" Header="Deployment destination root" ToolTipService.ToolTip="MSI-owned installs should use Program Files. Script publish is for development/admin bridge workflows." />
                                    <TextBox x:Name="ExecutableNameBox" Header="Executable name" ToolTipService.ToolTip="Service executable name used by deployment scripts." />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Button
                            HorizontalAlignment="Left"
                            AutomationProperties.Name="Save guided settings"
                            Click="SaveGuided_Click"
                            ToolTipService.ToolTip="Save guided configuration and run validation">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="16" Glyph="&#xE74E;" />
                                <TextBlock Text="Save Guided Settings" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="Advanced Keys" IsClosable="False">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="ConfigSourceFilterBox" Header="Source" SelectedIndex="0" SelectionChanged="ConfigFilter_Changed">
                            <ComboBoxItem Content="Any" />
                            <ComboBoxItem Content="Runtime" />
                            <ComboBoxItem Content="Deployment" />
                        </ComboBox>
                        <ComboBox x:Name="ConfigCategoryFilterBox" Grid.Column="1" Header="Category" SelectedIndex="0" SelectionChanged="ConfigFilter_Changed" />
                        <TextBox
                            x:Name="ConfigSearchBox"
                            Grid.Column="2"
                            Header="Search"
                            PlaceholderText="key, value, category, description"
                            TextChanged="ConfigSearchBox_TextChanged" />
                    </Grid>

                    <ListView
                        x:Name="ConfigEntriesList"
                        Grid.Row="1"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.HorizontalScrollMode="Disabled"
                        ScrollViewer.IsHorizontalRailEnabled="False"
                        ScrollViewer.IsHorizontalScrollChainingEnabled="False"
                        ScrollViewer.IsScrollInertiaEnabled="False"
                        ScrollViewer.IsVerticalScrollChainingEnabled="False"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        ScrollViewer.VerticalScrollMode="Enabled"
                        ScrollViewer.ZoomMode="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="8,6" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="2*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Source}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1" Text="{Binding Category}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{Binding Key}" TextTrimming="CharacterEllipsis" />
                                    <TextBox Grid.Column="3" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Column="4" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding HelpText}" TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Button
                        Grid.Row="2"
                        HorizontalAlignment="Left"
                        AutomationProperties.Name="Save advanced keys"
                        Click="SaveAdvanced_Click"
                        ToolTipService.ToolTip="Save advanced configuration keys and run validation">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="16" Glyph="&#xE74E;" />
                            <TextBlock Text="Save Advanced Keys" />
                        </StackPanel>
                    </Button>
                </Grid>
            </TabViewItem>

            <TabViewItem Header="Policy JSON" IsClosable="False">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button
                            AutomationProperties.Name="Format policy JSON"
                            Click="FormatPolicy_Click"
                            ToolTipService.ToolTip="Format policy JSON without saving">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="16" Glyph="&#xE70F;" />
                                <TextBlock Text="Format" />
                            </StackPanel>
                        </Button>
                        <Button
                            Grid.Column="1"
                            AutomationProperties.Name="Save policy JSON"
                            Click="SavePolicy_Click"
                            ToolTipService.ToolTip="Save formatted policy JSON and run validation">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="16" Glyph="&#xE74E;" />
                                <TextBlock Text="Save Policy" />
                            </StackPanel>
                        </Button>
                        <Button
                            Grid.Column="2"
                            AutomationProperties.Name="Open policy file"
                            Click="OpenPolicy_Click"
                            ToolTipService.ToolTip="Open policy file">
                            <FontIcon FontSize="16" Glyph="&#xE8A5;" />
                        </Button>
                    </Grid>

                    <TextBox
                        x:Name="PolicyJsonText"
                        Grid.Row="1"
                        AcceptsReturn="True"
                        FontFamily="Consolas"
                        FontSize="13"
                        TextWrapping="NoWrap"
                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                        ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabViewItem>

            <TabViewItem Header="Validation" IsClosable="False">
                <ScrollViewer
                    controls:PageScrollBehavior.UseReliableWheel="True"
                    Style="{StaticResource PageScrollViewerStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Resolved paths" />
                        <Border MinHeight="130" Style="{StaticResource ConsolePanelStyle}">
                            <TextBlock x:Name="PathText" Style="{StaticResource ConsoleTextStyle}" />
                        </Border>
                        <TextBlock FontWeight="SemiBold" Text="Validation" />
                        <Border MinHeight="430" Style="{StaticResource ConsolePanelStyle}">
                            <TextBlock x:Name="ValidationText" Style="{StaticResource ConsoleTextStyle}" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="Reset" IsClosable="False">
                <ScrollViewer
                    controls:PageScrollBehavior.UseReliableWheel="True"
                    Style="{StaticResource PageScrollViewerStyle}">
                    <Border Style="{StaticResource SectionCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock FontWeight="SemiBold" Text="Reset local config" />
                            <InfoBar
                                IsOpen="True"
                                Severity="Warning"
                                Title="Reset replaces operator-owned local settings"
                                Message="Use this only when you intentionally want defaults to replace local recipients, provider choices, thresholds, allowlists, policy tuning, baseline choices, and machine-specific paths." />
                            <CheckBox x:Name="ResetConfirmBox" Content="I understand this will back up then replace local runtime and deployment config with defaults." />
                            <Button
                                HorizontalAlignment="Left"
                                AutomationProperties.Name="Reset to defaults"
                                Click="ResetConfig_Click"
                                ToolTipService.ToolTip="Back up and replace local config with defaults">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="16" Glyph="&#xE777;" />
                                    <TextBlock Text="Reset to Defaults" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabViewItem>
        </TabView>
    </Grid>
</Page>

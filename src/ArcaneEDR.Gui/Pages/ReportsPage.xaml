<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ArcaneEDR_Gui.Pages.ReportsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource PagePadding}" Spacing="16">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Reports" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Daily report preview and delivery" />
                </StackPanel>
                <Button Grid.Column="1" Click="Preview_Click" ToolTipService.ToolTip="Preview daily report">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="16" Glyph="&#xE8A5;" />
                        <TextBlock Text="Preview" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Click="Json_Click" ToolTipService.ToolTip="Preview report JSON">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="16" Glyph="&#xE943;" />
                        <TextBlock Text="JSON" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="3" Click="Send_Click" ToolTipService.ToolTip="Send live daily report">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="16" Glyph="&#xE724;" />
                        <TextBlock Text="Send" />
                    </StackPanel>
                </Button>
            </Grid>

            <StackPanel Spacing="8">
                <TextBlock FontWeight="SemiBold" Text="Report output" />
                <Border MinHeight="560" Style="{StaticResource ConsolePanelStyle}">
                    <TextBlock x:Name="ReportOutputText" Style="{StaticResource ConsoleTextStyle}" />
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>

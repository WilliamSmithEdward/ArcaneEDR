<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ArcaneEDR_Gui.Pages.PolicyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource PagePadding}" Spacing="16">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Policy" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Unified scoped policy" />
                </StackPanel>
                <Button
                    Grid.Column="1"
                    AutomationProperties.Name="Inspect policy"
                    Click="Inspect_Click"
                    ToolTipService.ToolTip="Inspect policy">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="16" Glyph="&#xE721;" />
                        <TextBlock Text="Inspect" />
                    </StackPanel>
                </Button>
                <Button
                    Grid.Column="2"
                    AutomationProperties.Name="Preview sample policy match"
                    Click="Preview_Click"
                    ToolTipService.ToolTip="Preview sample policy match">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="16" Glyph="&#xE8A5;" />
                        <TextBlock Text="Preview" />
                    </StackPanel>
                </Button>
                <Button
                    Grid.Column="3"
                    AutomationProperties.Name="Open policy file"
                    Click="OpenPolicy_Click"
                    ToolTipService.ToolTip="Open policy file">
                    <FontIcon FontSize="16" Glyph="&#xE8A5;" />
                </Button>
                <Button
                    Grid.Column="4"
                    AutomationProperties.Name="Policy help"
                    Click="Help_Click"
                    ToolTipService.ToolTip="Explain policy safety model">
                    <FontIcon FontSize="16" Glyph="&#xE897;" />
                </Button>
            </Grid>

            <InfoBar
                x:Name="PolicyInfo"
                IsOpen="True"
                Severity="Informational"
                Title="JSONL evidence"
                Message="Policy decisions tune alerting and response gates while local alert evidence remains in JSONL." />

            <StackPanel Spacing="8">
                <TextBlock FontWeight="SemiBold" Text="Policy output" />
                <Border MinHeight="520" Style="{StaticResource ConsolePanelStyle}">
                    <TextBlock x:Name="PolicyOutputText" Style="{StaticResource ConsoleTextStyle}" />
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>

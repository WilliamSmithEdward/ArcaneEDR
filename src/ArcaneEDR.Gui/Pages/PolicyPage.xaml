<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ArcaneEDR_Gui.Pages.PolicyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:ArcaneEDR_Gui.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="{StaticResource PagePadding}" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Policy" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Unified scoped policy" />
            </StackPanel>
            <Button
                Grid.Column="1"
                AutomationProperties.Name="Inspect policy"
                Click="Inspect_Click"
                ToolTipService.ToolTip="Inspect policy">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="16" Glyph="&#xE721;" />
                    <TextBlock Text="Inspect" />
                </StackPanel>
            </Button>
            <Button
                Grid.Column="2"
                AutomationProperties.Name="Preview sample policy match"
                Click="Preview_Click"
                ToolTipService.ToolTip="Preview sample policy match">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="16" Glyph="&#xE8A5;" />
                    <TextBlock Text="Preview" />
                </StackPanel>
            </Button>
            <Button
                Grid.Column="3"
                AutomationProperties.Name="Open policy file"
                Click="OpenPolicy_Click"
                ToolTipService.ToolTip="Open policy file">
                <FontIcon FontSize="16" Glyph="&#xE8A5;" />
            </Button>
            <Button
                Grid.Column="4"
                AutomationProperties.Name="Policy help"
                Click="Help_Click"
                ToolTipService.ToolTip="Explain policy safety model">
                <FontIcon FontSize="16" Glyph="&#xE897;" />
            </Button>
        </Grid>

        <InfoBar
            x:Name="PolicyInfo"
            Grid.Row="1"
            IsOpen="True"
            Severity="Informational"
            Title="One policy list"
            Message="Add or edit one policy entry at a time. Order is shown consistently for every row; saves create a backup and validation shows any blockers." />

        <TabView x:Name="PolicyTabs" Grid.Row="2" IsAddTabButtonVisible="False">
            <TabViewItem Header="Entries" IsClosable="False">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Policy file" />
                                <TextBlock
                                    x:Name="PolicyPathText"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTipService.ToolTip="{Binding Text, ElementName=PolicyPathText}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Policy entries" />
                                <TextBlock x:Name="PolicyRuleCountText" Style="{StaticResource MetricValueTextStyle}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Allowlist countries" />
                                <TextBlock x:Name="PolicyCountryCountText" Style="{StaticResource MetricValueTextStyle}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Status" />
                                <TextBlock
                                    x:Name="PolicyLoadStatusText"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTipService.ToolTip="{Binding Text, ElementName=PolicyLoadStatusText}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" ColumnSpacing="10" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="190" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox
                            x:Name="PolicyScopeFilterBox"
                            Header="Type"
                            SelectedIndex="0"
                            SelectionChanged="PolicyFilter_Changed"
                            ToolTipService.ToolTip="Filter the list by policy type. This does not change policy behavior." />
                        <TextBox
                            x:Name="PolicySearchBox"
                            Grid.Column="1"
                            Header="Search"
                            PlaceholderText="id, action, owner, reason, match, country, process"
                            TextChanged="PolicySearchBox_TextChanged"
                            ToolTipService.ToolTip="Searches visible policy text only. It does not edit or disable policy entries." />
                        <CheckBox
                            x:Name="PolicyHideDisabledBox"
                            Grid.Column="2"
                            VerticalAlignment="Bottom"
                            Checked="PolicyFilter_Changed"
                            Content="Hide disabled"
                            IsChecked="True"
                            ToolTipService.ToolTip="Hide disabled policy entries in this list only."
                            Unchecked="PolicyFilter_Changed" />
                        <Button
                            x:Name="AddPolicyButton"
                            Grid.Column="3"
                            VerticalAlignment="Bottom"
                            AutomationProperties.Name="Add policy"
                            Click="AddPolicy_Click"
                            ToolTipService.ToolTip="Open the guided policy wizard. The new entry is not applied until you save.">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="15" Glyph="&#xE710;" />
                                <TextBlock Text="Add policy" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="MoveHigherButton"
                            Grid.Column="4"
                            Width="44"
                            VerticalAlignment="Bottom"
                            AutomationProperties.Name="Move policy up"
                            Click="MoveHigher_Click"
                            ToolTipService.ToolTip="Move selected policy up within its type">
                            <FontIcon FontSize="15" Glyph="&#xE74A;" />
                        </Button>
                        <Button
                            x:Name="MoveLowerButton"
                            Grid.Column="5"
                            Width="44"
                            VerticalAlignment="Bottom"
                            AutomationProperties.Name="Move policy down"
                            Click="MoveLower_Click"
                            ToolTipService.ToolTip="Move selected policy down within its type">
                            <FontIcon FontSize="15" Glyph="&#xE74B;" />
                        </Button>
                    </Grid>

                    <Grid Grid.Row="2" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.35*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Grid RowSpacing="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Padding="8,0" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52" />
                                    <ColumnDefinition Width="108" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="78" />
                                    <ColumnDefinition Width="92" />
                                </Grid.ColumnDefinitions>
                                <Button
                                    x:Name="SortOrderButton"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="SortOrder_Click"
                                    ToolTipService.ToolTip="Sort by display order. Move up/down changes saved file order within a policy type.">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock FontWeight="SemiBold" Text="Order" />
                                        <TextBlock x:Name="SortOrderIndicator" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    x:Name="SortTypeButton"
                                    Grid.Column="1"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="SortType_Click"
                                    ToolTipService.ToolTip="Sort by policy type. This is only a list view sort.">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock FontWeight="SemiBold" Text="Type" />
                                        <TextBlock x:Name="SortTypeIndicator" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    x:Name="SortPolicyButton"
                                    Grid.Column="2"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="SortPolicy_Click"
                                    ToolTipService.ToolTip="Sort by policy id or setting key.">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock FontWeight="SemiBold" Text="Policy" />
                                        <TextBlock x:Name="SortPolicyIndicator" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    x:Name="SortEnabledButton"
                                    Grid.Column="3"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="SortEnabled_Click"
                                    ToolTipService.ToolTip="Sort by enabled state.">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock FontWeight="SemiBold" Text="Enabled" />
                                        <TextBlock x:Name="SortEnabledIndicator" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    x:Name="SortActionButton"
                                    Grid.Column="4"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="SortAction_Click"
                                    ToolTipService.ToolTip="Sort by action.">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock FontWeight="SemiBold" Text="Action" />
                                        <TextBlock x:Name="SortActionIndicator" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <ListView
                                x:Name="PolicyEntriesList"
                                Grid.Row="1"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ScrollViewer.HorizontalScrollMode="Disabled"
                                ScrollViewer.IsHorizontalRailEnabled="False"
                                ScrollViewer.IsHorizontalScrollChainingEnabled="False"
                                ScrollViewer.IsScrollInertiaEnabled="False"
                                ScrollViewer.IsVerticalScrollChainingEnabled="False"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                ScrollViewer.VerticalScrollMode="Enabled"
                                ScrollViewer.ZoomMode="Disabled"
                                SelectionChanged="PolicyEntriesList_SelectionChanged">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="8,7" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="52" />
                                                <ColumnDefinition Width="108" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="78" />
                                                <ColumnDefinition Width="92" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                FontWeight="SemiBold"
                                                Text="{Binding PriorityDisplay}"
                                                ToolTipService.ToolTip="{Binding PriorityDisplay}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Grid.Column="1"
                                                Text="{Binding TypeDisplay}"
                                                ToolTipService.ToolTip="{Binding TypeDisplay}"
                                                TextTrimming="CharacterEllipsis" />
                                            <StackPanel Grid.Column="2" Spacing="2">
                                                <TextBlock
                                                    FontWeight="SemiBold"
                                                    Text="{Binding Id}"
                                                    ToolTipService.ToolTip="{Binding Id}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="{Binding MatchSummary}"
                                                    ToolTipService.ToolTip="{Binding MatchSummary}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <TextBlock
                                                Grid.Column="3"
                                                Text="{Binding EnabledDisplay}"
                                                ToolTipService.ToolTip="{Binding EnabledDisplay}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Grid.Column="4"
                                                Text="{Binding Action}"
                                                ToolTipService.ToolTip="{Binding Action}"
                                                TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>

                        <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}">
                            <Grid RowSpacing="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock
                                            x:Name="PolicyEditorTitleText"
                                            FontWeight="SemiBold"
                                            Text="Select a policy entry"
                                            TextTrimming="CharacterEllipsis"
                                            ToolTipService.ToolTip="{Binding Text, ElementName=PolicyEditorTitleText}" />
                                        <TextBlock
                                            x:Name="PolicyEditorModeText"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="Read and edit policy entries"
                                            TextTrimming="CharacterEllipsis"
                                            ToolTipService.ToolTip="{Binding Text, ElementName=PolicyEditorModeText}" />
                                    </StackPanel>
                                    <Button
                                        x:Name="FormatMatchButton"
                                        Grid.Column="1"
                                        AutomationProperties.Name="Format match JSON"
                                        Click="FormatMatch_Click"
                                        ToolTipService.ToolTip="Pretty-print the match/value JSON in the current editor. This does not save.">
                                        <FontIcon FontSize="15" Glyph="&#xE8A5;" />
                                    </Button>
                                    <Button
                                        x:Name="SavePolicyEntryButton"
                                        Grid.Column="2"
                                        AutomationProperties.Name="Save selected policy"
                                        Click="SavePolicyEntry_Click"
                                        ToolTipService.ToolTip="Save this policy entry, reload the policy list, and run validation. A backup is created first.">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon FontSize="15" Glyph="&#xE74E;" />
                                            <TextBlock Text="Save" />
                                        </StackPanel>
                                    </Button>
                                    <Button
                                        x:Name="DeletePolicyEntryButton"
                                        Grid.Column="3"
                                        AutomationProperties.Name="Delete selected policy"
                                        Click="DeletePolicyEntry_Click"
                                        ToolTipService.ToolTip="Delete the selected policy entry after confirmation. Local evidence already logged is not deleted.">
                                        <FontIcon FontSize="15" Glyph="&#xE74D;" />
                                    </Button>
                                </Grid>

                                <ScrollViewer
                                    Grid.Row="1"
                                    controls:PageScrollBehavior.UseReliableWheel="True"
                                    Style="{StaticResource PageScrollViewerStyle}">
                                    <StackPanel
                                        x:Name="PolicyEditorScrollContent"
                                        Margin="0,0,26,0"
                                        Spacing="10">
                                        <Grid ColumnSpacing="10" RowSpacing="8">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="96" />
                                            </Grid.ColumnDefinitions>
                                            <ComboBox
                                                x:Name="PolicyEditorScopeBox"
                                                Header="Policy type"
                                                MinWidth="220"
                                                SelectionChanged="PolicyEditorScope_Changed"
                                                ToolTipService.ToolTip="Shows what this entry controls. Existing entries keep their type locked so they cannot be accidentally moved between policy sections." />
                                            <TextBox
                                                x:Name="PolicyEditorPriorityText"
                                                Grid.Column="1"
                                                Header="Order"
                                                IsReadOnly="True"
                                                ToolTipService.ToolTip="Display order in the unified list. Move up/down changes file order within this policy type." />
                                            <StackPanel
                                                Grid.Row="1"
                                                Grid.ColumnSpan="2"
                                                HorizontalAlignment="Right"
                                                Orientation="Horizontal"
                                                Spacing="8">
                                                <Button
                                                    x:Name="EditorMoveHigherButton"
                                                    AutomationProperties.Name="Move selected policy up"
                                                    Click="MoveHigher_Click"
                                                    ToolTipService.ToolTip="Move this saved entry earlier within its policy type. Save new entries before moving.">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <FontIcon FontSize="15" Glyph="&#xE74A;" />
                                                        <TextBlock Text="Up" />
                                                    </StackPanel>
                                                </Button>
                                                <Button
                                                    x:Name="EditorMoveLowerButton"
                                                    AutomationProperties.Name="Move selected policy down"
                                                    Click="MoveLower_Click"
                                                    ToolTipService.ToolTip="Move this saved entry later within its policy type. Save new entries before moving.">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <FontIcon FontSize="15" Glyph="&#xE74B;" />
                                                        <TextBlock Text="Down" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock
                                            x:Name="PolicyOrderHintText"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            TextWrapping="Wrap" />

                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="132" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox
                                                x:Name="PolicyEditorIdBox"
                                                Header="Id / key"
                                                PlaceholderText="unique-policy-id"
                                                ToolTipService.ToolTip="Stable identifier for this entry. For list/map policy entries, this is the JSON key." />
                                            <ToggleSwitch
                                                x:Name="PolicyEditorEnabledSwitch"
                                                Grid.Column="1"
                                                Header="Enabled"
                                                IsOn="True"
                                                ToolTipService.ToolTip="Enable or disable this rule-type policy entry. JSON list/map entries are considered enabled when present." />
                                        </Grid>

                                        <StackPanel x:Name="RuleEditorPanel" Spacing="10">
                                            <Grid
                                                x:Name="DetectionMetadataPanel"
                                                ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="112" />
                                                    <ColumnDefinition Width="112" />
                                                </Grid.ColumnDefinitions>
                                                <ComboBox
                                                    x:Name="PolicyEditorActionBox"
                                                    Header="Action"
                                                    SelectionChanged="PolicyEditorAction_Changed"
                                                    ToolTipService.ToolTip="What Arcane should do when this policy matches. Available actions depend on policy type." />
                                                <TextBox
                                                    x:Name="PolicyEditorScoreBox"
                                                    Grid.Column="1"
                                                    Header="Score"
                                                    MaxLength="3"
                                                    PlaceholderText="90"
                                                    VerticalAlignment="Top"
                                                    ToolTipService.ToolTip="Optional absolute 0-100 score. Used only by actions that produce or set scored alert context." />
                                                <TextBox
                                                    x:Name="PolicyEditorScoreDeltaBox"
                                                    Grid.Column="2"
                                                    Header="Delta"
                                                    MaxLength="3"
                                                    PlaceholderText="10"
                                                    VerticalAlignment="Top"
                                                    ToolTipService.ToolTip="Optional amount to raise or lower an alert score. Used only by raise_score and lower_score alert tuning actions." />
                                            </Grid>

                                            <TextBlock
                                                x:Name="PolicyScoreHintText"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                TextWrapping="Wrap" />

                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="256" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox
                                                x:Name="PolicyEditorOwnerBox"
                                                Header="Owner"
                                                PlaceholderText="local-operator"
                                                ToolTipService.ToolTip="Optional owner or reviewer for alert tuning entries." />
                                            <TextBox
                                                x:Name="PolicyEditorTagBox"
                                                Grid.Column="1"
                                                Header="Tag"
                                                PlaceholderText="maintenance"
                                                ToolTipService.ToolTip="Optional tag added to policy context when this alert tuning entry applies." />
                                            <Grid
                                                Grid.Column="2"
                                                ColumnSpacing="8"
                                                ToolTipService.ToolTip="Optional UTC expiration for temporary alert tuning. Leave blank for no expiration.">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="88" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <CalendarDatePicker
                                                    x:Name="PolicyEditorExpiresDatePicker"
                                                    Header="Expires UTC date"
                                                    DateChanged="PolicyEditorExpirationDate_Changed"
                                                    PlaceholderText="No expiration" />
                                                <TimePicker
                                                    x:Name="PolicyEditorExpiresTimePicker"
                                                    Grid.Column="1"
                                                    Header="UTC time"
                                                    ClockIdentifier="24HourClock"
                                                    TimeChanged="PolicyEditorExpirationTime_Changed"
                                                    ToolTipService.ToolTip="UTC time for the selected expiration date." />
                                                <Button
                                                    x:Name="PolicyEditorClearExpiresButton"
                                                    Grid.Column="2"
                                                    VerticalAlignment="Bottom"
                                                    AutomationProperties.Name="Clear policy expiration"
                                                    Click="ClearEditorExpiration_Click"
                                                    ToolTipService.ToolTip="Clear expiration so this policy does not expire.">
                                                    <FontIcon FontSize="14" Glyph="&#xE711;" />
                                                </Button>
                                            </Grid>
                                            </Grid>

                                            <TextBox
                                                x:Name="PolicyEditorReasonBox"
                                                Header="Reason"
                                                AcceptsReturn="True"
                                                MinHeight="64"
                                                TextWrapping="Wrap"
                                                ToolTipService.ToolTip="Plain-English reason shown in audits and useful later when reviewing why this policy exists." />

                                            <TextBox
                                                x:Name="PolicyEditorMatchJsonBox"
                                                Header="Match JSON"
                                                AcceptsReturn="True"
                                                FontFamily="Consolas"
                                                MinHeight="170"
                                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                TextWrapping="NoWrap"
                                                ToolTipService.ToolTip="JSON object with the fields that must match before this rule applies. Use Format to pretty-print before saving." />
                                        </StackPanel>

                                        <StackPanel x:Name="SettingEditorPanel" Spacing="10">
                                            <TextBlock
                                                x:Name="PolicyEditorSettingHelpText"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                TextWrapping="Wrap" />
                                            <TextBox
                                                x:Name="PolicyEditorSettingValueBox"
                                                Header="Value JSON"
                                                AcceptsReturn="True"
                                                FontFamily="Consolas"
                                                MinHeight="240"
                                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                TextWrapping="NoWrap"
                                                ToolTipService.ToolTip="JSON value for list/map policy entries. Usually an array or object; use Format before saving." />
                                        </StackPanel>

                                        <Border Style="{StaticResource ConsolePanelStyle}">
                                            <TextBlock x:Name="SelectedPolicyDetailText" Style="{StaticResource ConsoleTextStyle}" />
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>

                                <TextBlock
                                    x:Name="PolicyEditorStatusText"
                                    Grid.Row="2"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="No policy changes pending."
                                    TextWrapping="Wrap" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabViewItem>

            <TabViewItem Header="Inspect Output" IsClosable="False">
                <ScrollViewer
                    controls:PageScrollBehavior.UseReliableWheel="True"
                    Style="{StaticResource PageScrollViewerStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Policy output" />
                        <Border MinHeight="520" Style="{StaticResource ConsolePanelStyle}">
                            <TextBlock x:Name="PolicyOutputText" Style="{StaticResource ConsoleTextStyle}" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="Raw JSON" IsClosable="False">
                <ScrollViewer
                    controls:PageScrollBehavior.UseReliableWheel="True"
                    Style="{StaticResource PageScrollViewerStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Current unified policy file" />
                        <Border MinHeight="520" Style="{StaticResource ConsolePanelStyle}">
                            <TextBlock x:Name="PolicyRawText" Style="{StaticResource ConsoleTextStyle}" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>
        </TabView>
    </Grid>
</Page>

<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ArcaneEDR_Gui.Pages.AlertsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="{StaticResource PagePadding}" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Alerts" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Filter, sort, and inspect local alert evidence" />
            </StackPanel>
            <Button
                Grid.Column="1"
                AutomationProperties.Name="Refresh alerts"
                Click="Refresh_Click"
                ToolTipService.ToolTip="Refresh alert volume and rows">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="16" Glyph="&#xE72C;" />
                    <TextBlock Text="Refresh" />
                </StackPanel>
            </Button>
            <Button
                Grid.Column="2"
                AutomationProperties.Name="Open log directory"
                Click="OpenLogs_Click"
                ToolTipService.ToolTip="Open log directory">
                <FontIcon FontSize="16" Glyph="&#xE838;" />
            </Button>
            <Button
                Grid.Column="3"
                AutomationProperties.Name="Alerts help"
                Click="Help_Click"
                ToolTipService.ToolTip="Explain alert table filters and evidence">
                <FontIcon FontSize="16" Glyph="&#xE897;" />
            </Button>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="10" RowSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="LookbackBox" Header="Lookback" SelectedIndex="2" SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="10m" />
                <ComboBoxItem Content="1h" />
                <ComboBoxItem Content="24h" />
                <ComboBoxItem Content="7d" />
                <ComboBoxItem Content="All" />
            </ComboBox>
            <ComboBox x:Name="SeverityBox" Grid.Column="1" Header="Severity" SelectedIndex="0" SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="Any" />
                <ComboBoxItem Content="Critical" />
                <ComboBoxItem Content="High" />
                <ComboBoxItem Content="Medium" />
                <ComboBoxItem Content="Low" />
            </ComboBox>
            <ComboBox x:Name="CategoryBox" Grid.Column="2" Header="Category" SelectedIndex="0" SelectionChanged="Filter_Changed" />
            <ComboBox x:Name="SortBox" Grid.Column="3" Header="Sort" SelectedIndex="0" SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="Time" />
                <ComboBoxItem Content="Score" />
                <ComboBoxItem Content="Rule" />
                <ComboBoxItem Content="Category" />
                <ComboBoxItem Content="Country" />
                <ComboBoxItem Content="Company" />
            </ComboBox>
            <ComboBox x:Name="SortDirectionBox" Grid.Column="4" Header="Direction" SelectedIndex="0" SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="Desc" />
                <ComboBoxItem Content="Asc" />
            </ComboBox>
            <CheckBox
                x:Name="ExternalCandidatesBox"
                Grid.Column="5"
                VerticalAlignment="Bottom"
                Checked="Filter_Changed"
                Content="External threshold"
                ToolTipService.ToolTip="Filter to rows at or above the configured MinimumEmailScore"
                Unchecked="Filter_Changed" />
            <TextBox
                x:Name="SearchBox"
                Grid.Column="6"
                Header="Search"
                PlaceholderText="rule, process, company, country, remote IP"
                TextChanged="SearchBox_TextChanged" />
        </Grid>

        <TabView Grid.Row="2">
            <TabViewItem Header="Table" IsClosable="False">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="TableSummaryText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

                    <Grid Grid.Row="1" RowSpacing="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Padding="8,0" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.3*" />
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="0.8*" />
                                <ColumnDefinition Width="0.6*" />
                                <ColumnDefinition Width="0.7*" />
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="1.3*" />
                                <ColumnDefinition Width="2.4*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontWeight="SemiBold" Text="UTC" />
                            <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="Rule" />
                            <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="Category" />
                            <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="Score" />
                            <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="Country" />
                            <TextBlock Grid.Column="5" FontWeight="SemiBold" Text="Process" />
                            <TextBlock Grid.Column="6" FontWeight="SemiBold" Text="Company" />
                            <TextBlock Grid.Column="7" FontWeight="SemiBold" Text="Title" />
                        </Grid>
                        <ListView
                            x:Name="AlertsList"
                            Grid.Row="1"
                            SelectionChanged="AlertsList_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="8,7" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.3*" />
                                            <ColumnDefinition Width="1.1*" />
                                            <ColumnDefinition Width="0.8*" />
                                            <ColumnDefinition Width="0.6*" />
                                            <ColumnDefinition Width="0.7*" />
                                            <ColumnDefinition Width="1.1*" />
                                            <ColumnDefinition Width="1.3*" />
                                            <ColumnDefinition Width="2.4*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontFamily="Consolas" Text="{Binding TimestampUtc}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" Text="{Binding RuleId}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" Text="{Binding Category}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="3" Text="{Binding Score}" />
                                        <TextBlock Grid.Column="4" Text="{Binding Country}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="5" Text="{Binding Process}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="6" Text="{Binding Company}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="7" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>

                    <Border Grid.Row="2" MinHeight="120" Style="{StaticResource ConsolePanelStyle}">
                        <TextBox x:Name="SelectedAlertText" Style="{StaticResource ConsoleTextBoxStyle}" />
                    </Border>
                </Grid>
            </TabViewItem>

            <TabViewItem Header="Volume" IsClosable="False">
                <ScrollViewer>
                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Configured alert context" />
                        <TextBlock x:Name="AlertConfigContextText" TextWrapping="Wrap" />
                        <Border MinHeight="360" Style="{StaticResource ConsolePanelStyle}">
                            <TextBox x:Name="VolumeText" Style="{StaticResource ConsoleTextBoxStyle}" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="Raw JSONL" IsClosable="False">
                <ScrollViewer>
                    <Border MinHeight="520" Style="{StaticResource ConsolePanelStyle}">
                        <TextBox x:Name="RecentAlertsText" Style="{StaticResource ConsoleTextBoxStyle}" />
                    </Border>
                </ScrollViewer>
            </TabViewItem>
        </TabView>
    </Grid>
</Page>

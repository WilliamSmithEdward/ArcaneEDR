<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ArcaneEDR_Gui.Pages.AlertsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:ArcaneEDR_Gui.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <controls:AlertTableColumnWidths x:Key="AlertColumnWidths" />
        <Style x:Key="AlertHeaderButtonStyle" TargetType="Button">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="8,7" />
        </Style>
        <Style x:Key="AlertCellTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="ColumnResizeHandleStyle" TargetType="controls:CursorResizeHandle">
            <Setter Property="Width" Value="14" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="controls:CursorResizeHandle">
                        <Grid Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="2">
                                <Rectangle
                                    Width="2"
                                    Height="18"
                                    Fill="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                    Opacity="0.7"
                                    RadiusX="1"
                                    RadiusY="1" />
                            </StackPanel>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Padding="{StaticResource PagePadding}" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Alerts" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Filter, sort, and inspect local alert evidence" />
            </StackPanel>
            <Button
                Grid.Column="1"
                AutomationProperties.Name="Refresh alerts"
                Click="Refresh_Click"
                ToolTipService.ToolTip="Refresh alert volume and rows">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="16" Glyph="&#xE72C;" />
                    <TextBlock Text="Refresh" />
                </StackPanel>
            </Button>
            <Button
                Grid.Column="2"
                AutomationProperties.Name="Copy visible alerts as CSV"
                Click="CopyCsv_Click"
                ToolTipService.ToolTip="Copy the current filtered alert rows as CSV">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="16" Glyph="&#xE8C8;" />
                    <TextBlock Text="Copy CSV" />
                </StackPanel>
            </Button>
            <Button
                Grid.Column="3"
                AutomationProperties.Name="Export visible alerts as CSV"
                Click="ExportCsv_Click"
                ToolTipService.ToolTip="Export the current filtered alert rows as CSV">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="16" Glyph="&#xEDE1;" />
                    <TextBlock Text="Export" />
                </StackPanel>
            </Button>
            <Button
                Grid.Column="4"
                AutomationProperties.Name="Open log directory"
                Click="OpenLogs_Click"
                ToolTipService.ToolTip="Open log directory">
                <FontIcon FontSize="16" Glyph="&#xE838;" />
            </Button>
            <Button
                Grid.Column="5"
                AutomationProperties.Name="Alerts help"
                Click="Help_Click"
                ToolTipService.ToolTip="Explain alert table filters and evidence">
                <FontIcon FontSize="16" Glyph="&#xE897;" />
            </Button>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="10" RowSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="LookbackBox" Header="Lookback" SelectedIndex="2" SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="10m" />
                <ComboBoxItem Content="1h" />
                <ComboBoxItem Content="24h" />
                <ComboBoxItem Content="7d" />
                <ComboBoxItem Content="All" />
            </ComboBox>
            <ComboBox x:Name="SeverityBox" Grid.Column="1" Header="Severity" SelectedIndex="0" SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="Any" />
                <ComboBoxItem Content="Critical" />
                <ComboBoxItem Content="High" />
                <ComboBoxItem Content="Medium" />
                <ComboBoxItem Content="Low" />
            </ComboBox>
            <ComboBox x:Name="CategoryBox" Grid.Column="2" Header="Category" SelectedIndex="0" SelectionChanged="Filter_Changed" />
            <CheckBox
                x:Name="ExternalCandidatesBox"
                Grid.Column="3"
                VerticalAlignment="Bottom"
                Checked="Filter_Changed"
                Content="External threshold"
                ToolTipService.ToolTip="Filter to rows at or above the configured MinimumEmailScore"
                Unchecked="Filter_Changed" />
            <TextBox
                x:Name="SearchBox"
                Grid.Column="4"
                Header="Search"
                PlaceholderText="rule, process, company, country, remote IP"
                TextChanged="SearchBox_TextChanged"
                ToolTipService.ToolTip="Searches the visible alert table by rule, process, company, country, remote IP, title, and policy context." />
        </Grid>

        <TabView Grid.Row="2" IsAddTabButtonVisible="False">
            <TabViewItem Header="Table" IsClosable="False">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="8" />
                        <RowDefinition
                            x:Name="AlertDetailsRow"
                            Height="180"
                            MinHeight="100" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="TableSummaryText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

                    <Border Grid.Row="1" Style="{StaticResource SectionCardStyle}">
                        <ScrollViewer
                            x:Name="AlertTableHorizontalScroller"
                            HorizontalScrollBarVisibility="Auto"
                            HorizontalScrollMode="Enabled"
                            IsHorizontalRailEnabled="False"
                            IsHorizontalScrollChainingEnabled="False"
                            IsVerticalScrollChainingEnabled="False"
                            VerticalScrollBarVisibility="Disabled"
                            VerticalScrollMode="Disabled"
                            ZoomMode="Disabled">
                            <Grid
                                MinWidth="{Binding TotalWidth, Source={StaticResource AlertColumnWidths}}"
                                RowSpacing="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    MinWidth="{Binding TotalWidth, Source={StaticResource AlertColumnWidths}}"
                                    Orientation="Horizontal">
                                    <Grid Width="{Binding Time, Source={StaticResource AlertColumnWidths}}">
                                        <Button
                                            AutomationProperties.Name="Sort by system time"
                                            Click="SortHeader_Click"
                                            Style="{StaticResource AlertHeaderButtonStyle}"
                                            Tag="Time"
                                            ToolTipService.ToolTip="Sort by system local time">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock FontWeight="SemiBold" Text="System time" />
                                                <TextBlock
                                                    x:Name="TimeSortIndicator"
                                                    MinWidth="14"
                                                    FontFamily="Segoe UI Symbol" />
                                            </StackPanel>
                                        </Button>
                                        <controls:CursorResizeHandle
                                            x:Name="TimeColumnResizeHandle"
                                            CursorShape="SizeWestEast"
                                            Style="{StaticResource ColumnResizeHandleStyle}"
                                            Tag="Time"
                                            ToolTipService.ToolTip="Resize System time column" />
                                    </Grid>
                                    <Grid Width="{Binding Rule, Source={StaticResource AlertColumnWidths}}">
                                        <Button
                                            AutomationProperties.Name="Sort by rule"
                                            Click="SortHeader_Click"
                                            Style="{StaticResource AlertHeaderButtonStyle}"
                                            Tag="Rule"
                                            ToolTipService.ToolTip="Sort by rule">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock FontWeight="SemiBold" Text="Rule" />
                                                <TextBlock
                                                    x:Name="RuleSortIndicator"
                                                    MinWidth="14"
                                                    FontFamily="Segoe UI Symbol" />
                                            </StackPanel>
                                        </Button>
                                        <controls:CursorResizeHandle x:Name="RuleColumnResizeHandle" CursorShape="SizeWestEast" Style="{StaticResource ColumnResizeHandleStyle}" Tag="Rule" ToolTipService.ToolTip="Resize Rule column" />
                                    </Grid>
                                    <Grid Width="{Binding Category, Source={StaticResource AlertColumnWidths}}">
                                        <Button
                                            AutomationProperties.Name="Sort by category"
                                            Click="SortHeader_Click"
                                            Style="{StaticResource AlertHeaderButtonStyle}"
                                            Tag="Category"
                                            ToolTipService.ToolTip="Sort by category">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock FontWeight="SemiBold" Text="Category" />
                                                <TextBlock
                                                    x:Name="CategorySortIndicator"
                                                    MinWidth="14"
                                                    FontFamily="Segoe UI Symbol" />
                                            </StackPanel>
                                        </Button>
                                        <controls:CursorResizeHandle x:Name="CategoryColumnResizeHandle" CursorShape="SizeWestEast" Style="{StaticResource ColumnResizeHandleStyle}" Tag="Category" ToolTipService.ToolTip="Resize Category column" />
                                    </Grid>
                                    <Grid Width="{Binding Score, Source={StaticResource AlertColumnWidths}}">
                                        <Button
                                            AutomationProperties.Name="Sort by score"
                                            Click="SortHeader_Click"
                                            Style="{StaticResource AlertHeaderButtonStyle}"
                                            Tag="Score"
                                            ToolTipService.ToolTip="Sort by score">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock FontWeight="SemiBold" Text="Score" />
                                                <TextBlock
                                                    x:Name="ScoreSortIndicator"
                                                    MinWidth="14"
                                                    FontFamily="Segoe UI Symbol" />
                                            </StackPanel>
                                        </Button>
                                        <controls:CursorResizeHandle x:Name="ScoreColumnResizeHandle" CursorShape="SizeWestEast" Style="{StaticResource ColumnResizeHandleStyle}" Tag="Score" ToolTipService.ToolTip="Resize Score column" />
                                    </Grid>
                                    <Grid Width="{Binding Notification, Source={StaticResource AlertColumnWidths}}">
                                        <Button
                                            AutomationProperties.Name="Sort by notification status"
                                            Click="SortHeader_Click"
                                            Style="{StaticResource AlertHeaderButtonStyle}"
                                            Tag="Notification"
                                            ToolTipService.ToolTip="Sort by external notification status">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon
                                                    FontFamily="Segoe MDL2 Assets"
                                                    FontSize="14"
                                                    Glyph="&#xE7ED;" />
                                                <TextBlock
                                                    x:Name="NotificationSortIndicator"
                                                    MinWidth="14"
                                                    FontFamily="Segoe UI Symbol" />
                                            </StackPanel>
                                        </Button>
                                        <controls:CursorResizeHandle x:Name="NotificationColumnResizeHandle" CursorShape="SizeWestEast" Style="{StaticResource ColumnResizeHandleStyle}" Tag="Notification" ToolTipService.ToolTip="Resize Notification column" />
                                    </Grid>
                                    <Grid Width="{Binding Country, Source={StaticResource AlertColumnWidths}}">
                                        <Button
                                            AutomationProperties.Name="Sort by country"
                                            Click="SortHeader_Click"
                                            Style="{StaticResource AlertHeaderButtonStyle}"
                                            Tag="Country"
                                            ToolTipService.ToolTip="Sort by country">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock FontWeight="SemiBold" Text="Country" />
                                                <TextBlock
                                                    x:Name="CountrySortIndicator"
                                                    MinWidth="14"
                                                    FontFamily="Segoe UI Symbol" />
                                            </StackPanel>
                                        </Button>
                                        <controls:CursorResizeHandle x:Name="CountryColumnResizeHandle" CursorShape="SizeWestEast" Style="{StaticResource ColumnResizeHandleStyle}" Tag="Country" ToolTipService.ToolTip="Resize Country column" />
                                    </Grid>
                                    <Grid Width="{Binding Process, Source={StaticResource AlertColumnWidths}}">
                                        <Button
                                            AutomationProperties.Name="Sort by process"
                                            Click="SortHeader_Click"
                                            Style="{StaticResource AlertHeaderButtonStyle}"
                                            Tag="Process"
                                            ToolTipService.ToolTip="Sort by process">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock FontWeight="SemiBold" Text="Process" />
                                                <TextBlock
                                                    x:Name="ProcessSortIndicator"
                                                    MinWidth="14"
                                                    FontFamily="Segoe UI Symbol" />
                                            </StackPanel>
                                        </Button>
                                        <controls:CursorResizeHandle x:Name="ProcessColumnResizeHandle" CursorShape="SizeWestEast" Style="{StaticResource ColumnResizeHandleStyle}" Tag="Process" ToolTipService.ToolTip="Resize Process column" />
                                    </Grid>
                                    <Grid Width="{Binding Company, Source={StaticResource AlertColumnWidths}}">
                                        <Button
                                            AutomationProperties.Name="Sort by company"
                                            Click="SortHeader_Click"
                                            Style="{StaticResource AlertHeaderButtonStyle}"
                                            Tag="Company"
                                            ToolTipService.ToolTip="Sort by company">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock FontWeight="SemiBold" Text="Company" />
                                                <TextBlock
                                                    x:Name="CompanySortIndicator"
                                                    MinWidth="14"
                                                    FontFamily="Segoe UI Symbol" />
                                            </StackPanel>
                                        </Button>
                                        <controls:CursorResizeHandle x:Name="CompanyColumnResizeHandle" CursorShape="SizeWestEast" Style="{StaticResource ColumnResizeHandleStyle}" Tag="Company" ToolTipService.ToolTip="Resize Company column" />
                                    </Grid>
                                    <Grid Width="{Binding Title, Source={StaticResource AlertColumnWidths}}">
                                        <Button
                                            AutomationProperties.Name="Sort by title"
                                            Click="SortHeader_Click"
                                            Style="{StaticResource AlertHeaderButtonStyle}"
                                            Tag="Title"
                                            ToolTipService.ToolTip="Sort by title">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock FontWeight="SemiBold" Text="Title" />
                                                <TextBlock
                                                    x:Name="TitleSortIndicator"
                                                    MinWidth="14"
                                                    FontFamily="Segoe UI Symbol" />
                                            </StackPanel>
                                        </Button>
                                        <controls:CursorResizeHandle x:Name="TitleColumnResizeHandle" CursorShape="SizeWestEast" Style="{StaticResource ColumnResizeHandleStyle}" Tag="Title" ToolTipService.ToolTip="Resize Title column" />
                                    </Grid>
                                </StackPanel>

                                <ListView
                                    x:Name="AlertsList"
                                    Grid.Row="1"
                                    MinWidth="{Binding TotalWidth, Source={StaticResource AlertColumnWidths}}"
                                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                    ScrollViewer.HorizontalScrollMode="Disabled"
                                    ScrollViewer.IsHorizontalRailEnabled="False"
                                    ScrollViewer.IsHorizontalScrollChainingEnabled="False"
                                    ScrollViewer.IsScrollInertiaEnabled="False"
                                    ScrollViewer.IsVerticalScrollChainingEnabled="False"
                                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                                    ScrollViewer.VerticalScrollMode="Enabled"
                                    ScrollViewer.ZoomMode="Disabled"
                                    SelectionChanged="AlertsList_SelectionChanged">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel
                                                MinWidth="{Binding TotalWidth, Source={StaticResource AlertColumnWidths}}"
                                                Orientation="Horizontal"
                                                Padding="0,6"
                                                RightTapped="AlertRow_RightTapped">
                                                <StackPanel.ContextFlyout>
                                                    <MenuFlyout>
                                                        <MenuFlyoutItem
                                                            Text="Create policy from alert..."
                                                            CommandParameter="{Binding}"
                                                            Click="CreatePolicyFromAlert_Click"
                                                            ToolTipService.ToolTip="Open a guided policy wizard using metadata from this alert." />
                                                    </MenuFlyout>
                                                </StackPanel.ContextFlyout>
                                                <TextBlock
                                                    Width="{Binding Time, Source={StaticResource AlertColumnWidths}}"
                                                    FontFamily="Consolas"
                                                    Style="{StaticResource AlertCellTextStyle}"
                                                    Text="{Binding SystemTimeDisplay}"
                                                    ToolTipService.ToolTip="{Binding SystemTimeDisplay}" />
                                                <TextBlock Width="{Binding Rule, Source={StaticResource AlertColumnWidths}}" Style="{StaticResource AlertCellTextStyle}" Text="{Binding RuleId}" ToolTipService.ToolTip="{Binding RuleId}" />
                                                <TextBlock Width="{Binding Category, Source={StaticResource AlertColumnWidths}}" Style="{StaticResource AlertCellTextStyle}" Text="{Binding Category}" ToolTipService.ToolTip="{Binding Category}" />
                                                <TextBlock Width="{Binding Score, Source={StaticResource AlertColumnWidths}}" Style="{StaticResource AlertCellTextStyle}" Text="{Binding Score}" ToolTipService.ToolTip="{Binding Score}" />
                                                <TextBlock
                                                    Width="{Binding Notification, Source={StaticResource AlertColumnWidths}}"
                                                    FontFamily="Segoe MDL2 Assets"
                                                    FontSize="16"
                                                    HorizontalTextAlignment="Center"
                                                    Style="{StaticResource AlertCellTextStyle}"
                                                    Text="{Binding ExternalNotificationGlyph}"
                                                    ToolTipService.ToolTip="{Binding ExternalNotificationDisplay}" />
                                                <TextBlock Width="{Binding Country, Source={StaticResource AlertColumnWidths}}" Style="{StaticResource AlertCellTextStyle}" Text="{Binding Country}" ToolTipService.ToolTip="{Binding Country}" />
                                                <TextBlock Width="{Binding Process, Source={StaticResource AlertColumnWidths}}" Style="{StaticResource AlertCellTextStyle}" Text="{Binding Process}" ToolTipService.ToolTip="{Binding Process}" />
                                                <TextBlock Width="{Binding Company, Source={StaticResource AlertColumnWidths}}" Style="{StaticResource AlertCellTextStyle}" Text="{Binding Company}" ToolTipService.ToolTip="{Binding Company}" />
                                                <TextBlock Width="{Binding Title, Source={StaticResource AlertColumnWidths}}" Style="{StaticResource AlertCellTextStyle}" Text="{Binding Title}" ToolTipService.ToolTip="{Binding Title}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Row="2">
                        <Border
                            Height="1"
                            VerticalAlignment="Center"
                            Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                            Opacity="0.55" />
                        <controls:CursorResizeHandle
                            x:Name="AlertDetailsResizeHandle"
                            Width="96"
                            HorizontalAlignment="Center"
                            CursorShape="SizeNorthSouth"
                            ToolTipService.ToolTip="Resize alert metadata panel">
                            <controls:CursorResizeHandle.Template>
                                <ControlTemplate TargetType="controls:CursorResizeHandle">
                                    <Grid Background="Transparent">
                                        <Border
                                            Width="74"
                                            Height="6"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            CornerRadius="3"
                                            Opacity="0.78">
                                            <StackPanel
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal"
                                                Spacing="5">
                                                <Rectangle
                                                    Width="24"
                                                    Height="2"
                                                    Fill="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Opacity="0.68"
                                                    RadiusX="1"
                                                    RadiusY="1" />
                                                <Rectangle
                                                    Width="24"
                                                    Height="2"
                                                    Fill="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Opacity="0.68"
                                                    RadiusX="1"
                                                    RadiusY="1" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </ControlTemplate>
                            </controls:CursorResizeHandle.Template>
                        </controls:CursorResizeHandle>
                    </Grid>

                    <Border Grid.Row="3" Style="{StaticResource SectionCardStyle}">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontWeight="SemiBold" Text="Alert metadata" />
                                <Button
                                    x:Name="CreatePolicyFromSelectedAlertButton"
                                    Grid.Column="1"
                                    AutomationProperties.Name="Create policy from selected alert"
                                    Click="CreatePolicyFromAlert_Click"
                                    IsEnabled="False"
                                    ToolTipService.ToolTip="Open a guided policy wizard using metadata from the selected alert.">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="14" Glyph="&#xE710;" />
                                        <TextBlock Text="Create policy" />
                                    </StackPanel>
                                </Button>
                                <TextBlock
                                    x:Name="SelectedAlertHintText"
                                    Grid.Column="2"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Select an alert"
                                    ToolTipService.ToolTip="{Binding Text, ElementName=SelectedAlertHintText}"
                                    TextTrimming="CharacterEllipsis" />
                            </Grid>
                            <ScrollViewer
                                Grid.Row="1"
                                controls:PageScrollBehavior.UseReliableWheel="True"
                                Style="{StaticResource PageScrollViewerStyle}">
                                <StackPanel Spacing="10">
                                    <TextBlock FontWeight="SemiBold" Text="Metadata" />
                                    <Border Style="{StaticResource ConsolePanelStyle}">
                                        <TextBlock x:Name="SelectedAlertMetadataText" Style="{StaticResource ConsoleTextStyle}" />
                                    </Border>
                                    <TextBlock FontWeight="SemiBold" Text="Evidence" />
                                    <Border Style="{StaticResource ConsolePanelStyle}">
                                        <TextBlock x:Name="SelectedAlertEvidenceText" Style="{StaticResource ConsoleTextStyle}" />
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </TabViewItem>

            <TabViewItem Header="Volume" IsClosable="False">
                <ScrollViewer
                    controls:PageScrollBehavior.UseReliableWheel="True"
                    Style="{StaticResource PageScrollViewerStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Configured alert context" />
                        <TextBlock x:Name="AlertConfigContextText" TextWrapping="Wrap" />
                        <Border MinHeight="360" Style="{StaticResource ConsolePanelStyle}">
                            <TextBlock x:Name="VolumeText" Style="{StaticResource ConsoleTextStyle}" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="Raw JSONL" IsClosable="False">
                <ScrollViewer
                    controls:PageScrollBehavior.UseReliableWheel="True"
                    Style="{StaticResource PageScrollViewerStyle}">
                    <Border MinHeight="520" Style="{StaticResource ConsolePanelStyle}">
                        <TextBlock x:Name="RecentAlertsText" Style="{StaticResource ConsoleTextStyle}" />
                    </Border>
                </ScrollViewer>
            </TabViewItem>
        </TabView>
    </Grid>
</Page>
